{
    "name": "psc-acme/driver-order",
    "description": "Package driver-order for psc-acme organization",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Philipp Scheit",
            "email": "p.scheit@packagist.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "PscAcme\\DriverOrder\\": "src/"
        }
    },
    "require": {
        "php": ">=8.1",
        "symfony/cache": "^7.0",
        "symfony/messenger": "^7.0",
        "nikic/php-parser": "^5.0",
        "symfony/process": "^7.0",
        "nesbot/carbon": "^2.72"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "behat/behat": "^3.14",
        "fakerphp/faker": "^1.0"
    },
    "minimum-stability": "stable",
    "config": {
        "secure-http": false
    },
    "repositories": {
        "private-packagist": {
            "type": "composer",
            "url": "http://repo.packagist.com.lo/psc-acme/"
        },
        "packagist.org": false
    }
}